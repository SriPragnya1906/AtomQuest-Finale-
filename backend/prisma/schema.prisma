generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id           String        @id @default(uuid())
  createdAt    DateTime      @default(now())
  isActive     Boolean       @default(true)
  participants Participant[]
  messages     ChatMessage[]
  recordingUrl String?
  eventLogs    EventLog[]
  chatFiles    ChatFile[]
}

model Participant {
  id        String    @id @default(uuid())
  sessionId String
  session   Session   @relation(fields: [sessionId], references: [id])
  role      String    // "AGENT" or "CUSTOMER"
  joinedAt  DateTime  @default(now())
  leftAt    DateTime?
  name      String?
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  senderId  String
  senderName String?
  text      String
  timestamp DateTime @default(now())
}

model ChatFile {
  id         String   @id @default(uuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id])
  name       String
  url        String
  size       Int
  mimeType   String
  senderId   String
  senderName String?
  uploadedAt DateTime @default(now())
}

model EventLog {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id])
  type      String   // "JOIN", "LEAVE", "DISCONNECT", "RECONNECT", "RECORDING_START", "RECORDING_STOP", "END_SESSION"
  message   String
  timestamp DateTime @default(now())
}
